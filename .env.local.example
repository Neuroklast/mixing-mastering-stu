# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Dev / Prototyping Mode ────────────────────────────────────────────────────
# Set to "true" to use local mock data instead of live Supabase calls.
# All services check this flag and return mock data with a simulated delay.
# Switch to "false" (or remove) to connect to the real backend.
NEXT_PUBLIC_DEV_MODE=true

# ── Contact form (Resend) ─────────────────────────────────────────────────────
RESEND_API_KEY=re_...
CONTACT_TO_EMAIL=hello@your-domain.com
CONTACT_FROM_EMAIL=noreply@your-domain.com

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy
# SENTRY_DSN=https://xxx@sentry.io/yyy

# ── Stripe (future VST shop) ──────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Cloudflare R2 (optional — set STORAGE_PROVIDER=r2 to use R2 instead of Supabase Storage)
# See docs/cloudflare-r2.md for setup instructions.
# STORAGE_PROVIDER=supabase
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_PUBLIC_HOST=
# R2_BUCKET_MEDIA=sonorativa-media
# R2_BUCKET_AUDIO=sonorativa-audio
