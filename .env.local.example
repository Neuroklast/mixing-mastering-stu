# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Dev / Prototyping Mode ────────────────────────────────────────────────────
# Set to "true" to use local mock data instead of live Supabase calls.
# All services check this flag and return mock data with a simulated delay.
# Switch to "false" (or remove) to connect to the real backend.
NEXT_PUBLIC_DEV_MODE=true

# ── Contact form / Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_...
CONTACT_TO_EMAIL=hello@your-domain.com
CONTACT_FROM_EMAIL=noreply@your-domain.com
# Admin email for new-order and review-invite notifications (defaults to CONTACT_FROM_EMAIL)
ADMIN_EMAIL=admin@your-domain.com

# ── Cloudflare R2 (required for file uploads and audio downloads) ─────────────
# Storage is handled exclusively by Cloudflare R2. Supabase Storage is not used.
# See docs/cloudflare-r2.md for full setup instructions.
# Run `node scripts/r2-setup.mjs` to provision buckets automatically.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# Public custom domain for the sonorativa-media bucket (images)
# Set this up in Cloudflare Dashboard → R2 → sonorativa-media → Settings → Public Access
R2_PUBLIC_HOST=media.your-domain.com
R2_BUCKET_MEDIA=sonorativa-media
R2_BUCKET_AUDIO=sonorativa-audio

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy
# SENTRY_DSN=https://xxx@sentry.io/yyy

# ── Stripe (future VST shop) ──────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
