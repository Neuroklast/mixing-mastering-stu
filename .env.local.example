# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Payload CMS ───────────────────────────────────────────────────────────────
# Supabase Postgres connection string (Session pooler recommended):
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
# Find in: Supabase dashboard → Project Settings → Database → Connection string → URI
DATABASE_URI=postgresql://postgres.PROJECT_REF:PASSWORD@host:5432/postgres
PAYLOAD_SECRET=your-secret-at-least-32-characters-long

# ── Supabase S3 Storage (for Payload media uploads) ───────────────────────────
# Find in: Supabase dashboard → Storage → S3 Connection
# The endpoint follows the pattern: https://<project-ref>.supabase.co/storage/v1/s3
S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
# Name of the Supabase storage bucket for Payload media (create it in the dashboard first)
S3_BUCKET=media

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── Dev / Prototyping Mode ────────────────────────────────────────────────────
# Set to "true" to use local mock data instead of live Supabase calls.
# All services check this flag and return mock data with a simulated delay.
# Switch to "false" (or remove) to connect to the real backend.
NEXT_PUBLIC_DEV_MODE=true

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy
# SENTRY_DSN=https://xxx@sentry.io/yyy

# ── Stripe (future VST shop) ──────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
