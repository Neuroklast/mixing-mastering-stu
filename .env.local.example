# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Payload CMS ───────────────────────────────────────────────────────────────
# Supabase Postgres connection string (Session pooler recommended):
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
DATABASE_URI=postgresql://postgres.PROJECT_REF:PASSWORD@host:5432/postgres
PAYLOAD_SECRET=your-secret-at-least-32-characters-long

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/yyy
# SENTRY_DSN=https://xxx@sentry.io/yyy

# ── Stripe (future VST shop) ──────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
