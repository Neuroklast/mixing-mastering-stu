{
  "name": "sonorativa",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--import tsx/esm' payload generate:types && next build"
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "scan": "npx tsx --tsconfig tsconfig.json scripts/scan-audio.ts",
    "scan:dry": "npx tsx --tsconfig tsconfig.json scripts/scan-audio.ts --dry-run",
    "setup": "bash scripts/setup.sh",
    "setup:db": "bash scripts/setup-db.sh",
    "setup:supabase": "bash bin/setup-supabase.sh",
    "payload:init": "bash scripts/payload-init.sh",
    "prepare": "husky"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.0.0",
    "@payloadcms/next": "^3.0.0",
    "@payloadcms/richtext-lexical": "^3.0.0",
    "@payloadcms/storage-s3": "^3.84.1",
    "@payloadcms/ui": "^3.0.0",
    "@phosphor-icons/react": "^2.1.7",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.43.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.0",
    "lenis": "^1.1.0",
    "next": "^16.2.2",
    "payload": "^3.0.0",
    "postprocessing": "^6.39.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.33.0",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.3.0",
    "three": "^0.184.0",
    "zod": "^3.23.0"
