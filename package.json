    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.2",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "lint-staged": "^15.5.2",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
